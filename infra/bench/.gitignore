# Terraform working state — never commit
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfstate.backup

# Plan output may contain sensitive values
*.tfplan
crash.log
crash.*.log

# Local override files (developer-specific)
*.auto.tfvars
*.auto.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
